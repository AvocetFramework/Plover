create.app ("App Title")

app.configs (
    size = 600px 800px; 
    mode = system;
) 

app.styling (
    import file {style.css};
)

app.content (
    class menubar {
        option1 = File {
            optionA = New File: command {onclick call script.plover} = Ctrl+N;
            optionB = Open File: command {onclick call script.plover} = Ctrl+O;
            menubar divisor;
            optionC = Close App: command {onclick call script.plover} = Ctrl+A;
        }
    }
)

loop.app ()
